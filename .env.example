# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key (Settings > API > anon public)
SUPABASE_KEY=

# Resend API key for sending magic-link emails (resend.com > API Keys)
RESEND_API_KEY=

# Sender address verified in Resend (e.g. noreply@yourdomain.com)
FROM_EMAIL=
